{
  "name": "savoy-hotel-backend",
  "version": "1.0.0",
  "description": "Backend for Savoy Hotel website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "sequelize db:migrate --config config/config.js --migrations-path migrations",
    "migrate:undo": "sequelize db:migrate:undo --config config/config.js --migrations-path migrations",
    "seed": "sequelize db:seed:all --config config/config.js --seeders-path seeders",
    "seed:undo": "sequelize db:seed:undo:all --config config/config.js --seeders-path seeders",
    "data:import": "node utils/seeder.js -i",
    "data:destroy": "node utils/seeder.js -d"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.3.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.3.1",
    "node-cron": "^4.1.0",
    "sequelize": "^6.31.1",
    "sqlite3": "^6.0.1",
    "stripe": "^20.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "sequelize-cli": "^6.6.3"
  }
}
